# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Never commit real `.env`.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/winsume?retryWrites=true&w=majority

JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional: comma-separated origins. If unset in production, defaults include winsumelift.com (http/https + www).
# CORS_ORIGIN=https://winsumelift.com,https://www.winsumelift.com

# Optional upload subdirectory name (default: uploads)
# UPLOAD_DIR=uploads
